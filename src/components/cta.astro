---
import Link from "./ui/link.astro";
---

<div
  class="bg-brand-700 p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    Ready to get in the water?
  </h2>
  <p class="text-brand-100 mt-4 text-lg md:text-xl">
    See this week's open times and grab your spot — it takes less than a
    minute.
  </p>
  <div class="flex mt-5">
    <Link href="/book.html" style="inverted">Book a Lesson</Link>
  </div>
</div>

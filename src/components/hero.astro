---
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<div
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <!-- Stock stand-in (Unsplash license, downloaded into the repo):
         https://unsplash.com/photos/1530549387789-4c1017266635
         TODO: replace with a real photo of a KSJ lesson — drop it in
         public/images/ and change the src below. -->
    <img
      src="/images/hero-pool.jpg"
      alt="Swimmer doing butterfly stroke in a lap pool"
      width="1200"
      height="800"
      loading="eager"
      class="rounded-3xl shadow-lg object-cover aspect-[3/2]"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      Learn to swim with confidence
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      Private lessons with experienced coaches at pools across the city.
      Pick a time that fits your week and book in under a minute — no
      account needed, and you can manage everything from your email.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="/book.html"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-white w-5 h-5" name="bx:bxs-calendar-check" />
        Book a Lesson
      </Link>
      <Link
        size="lg"
        style="outline"
        href="/mybookings.html"
        class="flex gap-1 items-center justify-center">
        <Icon class="w-4 h-4" name="bx:bxs-user-check" />
        My Bookings
      </Link>
    </div>
  </div>
</div>

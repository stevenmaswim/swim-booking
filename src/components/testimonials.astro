---
import Sectionhead from "@/components/sectionhead.astro";

// TODO: replace these placeholder quotes with real parent testimonials
// (and real first names) once the owner collects them.
const testimonials = [
  {
    quote:
      "Our daughter went from clinging to the wall to swimming a full lap in one season. The weekly booking couldn't be easier.",
    name: "A KSJ parent",
  },
  {
    quote:
      "Both kids have lessons back-to-back at the same pool — one email, one booking, done.",
    name: "A KSJ parent",
  },
  {
    quote:
      "The coaches are patient and the reminder emails mean we never miss a lesson.",
    name: "A KSJ parent",
  },
];
---

<div class="mt-24">
  <Sectionhead>
    <Fragment slot="title">What Parents Say</Fragment>
    <Fragment slot="desc">Real families, real progress.</Fragment>
  </Sectionhead>

  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-10 mx-auto max-w-4xl mt-12">
    {
      testimonials.map((t) => (
        <figure class="bg-brand-50 rounded-2xl p-6">
          <blockquote class="text-slate-700 leading-relaxed">
            “{t.quote}”
          </blockquote>
          <figcaption class="mt-4 text-sm font-semibold text-brand-700">
            — {t.name}
          </figcaption>
        </figure>
      ))
    }
  </div>
</div>
